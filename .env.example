# ideamemo 環境変数
# .env.local にコピーして値を設定

# モックモード（true: 外部API全てモック / false: 本番API使用）
NEXT_PUBLIC_MOCK_MODE=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI APIs
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Web Search（接続発見の外部知識検索用）
BRAVE_SEARCH_API_KEY=
